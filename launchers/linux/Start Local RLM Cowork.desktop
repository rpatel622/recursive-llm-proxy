[Desktop Entry]
Type=Application
Name=Local RLM Cowork
Comment=Start private local AI in your browser
Exec=sh -c 'p=$(printf "%s" "$1" | sed "s#^file://##"); d=$(dirname "$p"); python3 "$d/../launcher.pyw"' local-rlm-cowork %k
Icon=applications-science
Terminal=false
Categories=Utility;Education;
StartupNotify=true
