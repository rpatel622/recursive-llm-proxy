#!/bin/sh
set -eu

APP_MACOS_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT=$(CDPATH= cd -- "$APP_MACOS_DIR/../../../../../" && pwd)
PYTHON="$ROOT/runtime/python/bin/python3"
LAUNCHER="$ROOT/launchers/launcher.pyw"

if [ ! -x "$PYTHON" ] || [ ! -f "$LAUNCHER" ]; then
    /usr/bin/osascript -e 'display alert "Local RLM Cowork" message "This bundle is incomplete. Download and fully extract the macOS release bundle, then try again." as critical'
    exit 1
fi

export PYTHONHOME="$ROOT/runtime/python"
exec "$PYTHON" "$LAUNCHER"
